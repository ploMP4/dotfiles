theme = TokyoNight Night
# Wallpaper-derived colors (generated by wallust). Optional (?) so ghostty
# falls back to the theme above before the first run. Overrides it once present.
config-file = ?wallust
font-family = Iosevka Nerd Font
background-opacity = 0.82
font-size = 20
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
font-feature = -calt

window-decoration = true
gtk-titlebar = false
keybind = shift+enter=text:\x1b\r
