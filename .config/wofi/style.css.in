/* Generated by wallust-apply.sh from ~/.config/wofi/style.css.in — do not edit style.css directly. */
/* Tokyo Night base with a wallpaper-derived accent (__ACCENT_RGB__) and tinted background (__BG_RGB__). */

* {
    font-family: "SF Pro", "JetBrainsMono Nerd Font", sans-serif;
    font-size: 14px;
}

window {
    margin: 0;
    border: 1px solid rgba(__ACCENT_RGB__, 0.3);
    border-radius: 8px;
    background-color: rgba(__BG_RGB__, 0.85);
}

#input {
    margin: 8px 10px;
    padding: 8px 12px;
    border: none;
    border-radius: 5px;
    color: #c0caf5;
    background-color: rgba(36, 40, 59, 0.8);
    font-size: 14px;
    transition: box-shadow 0.2s ease, background-color 0.2s ease;
}

#input:focus {
    border: none;
    background-color: rgba(36, 40, 59, 1);
    box-shadow: 0 0 0 2px rgba(__ACCENT_RGB__, 0.4);
}

#input image {
    color: #565f89;
}

#inner-box {
    margin: 0 10px 10px 10px;
    border: none;
    background-color: transparent;
}

#outer-box {
    margin: 0;
    padding: 0;
    border: none;
    background-color: transparent;
}

#scroll {
    margin: 0;
    border: none;
    background-color: transparent;
}

#text {
    margin: 0;
    padding: 0;
    border: none;
    color: #c0caf5;
    transition: color 0.15s ease;
}

#text:selected {
    color: #ffffff;
}

#entry {
    padding: 10px 12px;
    margin: 2px 0;
    border: none;
    border-radius: 6px;
    background-color: transparent;
    transition: all 0.18s ease;
}

#entry:selected {
    background-color: rgba(__ACCENT_RGB__, 0.2);
    border: none;
    padding-left: 16px;
}

#entry:hover {
    background-color: rgba(36, 40, 59, 0.6);
    padding-left: 14px;
}

#entry image {
    margin-right: 10px;
    transition: opacity 0.15s ease;
}

#entry:selected image {
    opacity: 1;
}

/* Scrollbar styling */
scrollbar {
    background: transparent;
    border: none;
}

scrollbar slider {
    background-color: rgba(86, 95, 137, 0.4);
    border-radius: 4px;
    min-width: 6px;
    min-height: 30px;
    transition: background-color 0.2s ease, min-width 0.15s ease;
}

scrollbar slider:hover {
    background-color: rgba(__ACCENT_RGB__, 0.6);
    min-width: 8px;
}
